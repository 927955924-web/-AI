{
  "name": "ecommerce-cs-client",
  "version": "1.6.4",
  "description": "E-commerce Customer Service Automation Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "mqtt": "^5.15.0"
  },
  "build": {
    "appId": "com.ecommerce.cs-client",
    "productName": "AI客服测试",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "generic",
      "url": "http://120.26.199.225:8080/releases/latest/win"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
